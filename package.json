{
  "name": "metaswarm",
  "version": "0.11.0",
  "description": "Cross-platform installer for metaswarm — multi-agent orchestration for Claude Code, Codex CLI, and Gemini CLI",
  "bin": {
    "metaswarm": "cli/metaswarm.js"
  },
  "files": [
    "cli/",
    "lib/",
    "agents/",
    "skills/",
    "commands/",
    "rubrics/",
    "knowledge/",
    "scripts/",
    "bin/",
    "templates/",
    "guides/",
    ".codex/",
    "ORCHESTRATION.md",
    "AGENTS.md",
    "GEMINI.md",
    "gemini-extension.json"
  ],
  "scripts": {
    "pack:build": "tsc -p tsconfig.pack.json --noEmit",
    "pack:test": "vitest run --config tests/pack-system/vitest.config.ts --passWithNoTests",
    "pack:test:coverage": "vitest run --config tests/pack-system/vitest.config.ts --coverage --passWithNoTests",
    "pack:test:contract": "echo 'pack:test:contract — placeholder; custom contract reporter lands in WU8 (plan §4.2)'",
    "pack:lint:anchors": "node scripts/lint-docs-anchors.js"
  },
  "keywords": [
    "claude-code",
    "codex-cli",
    "gemini-cli",
    "agents",
    "orchestration",
    "tdd",
    "beads"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dsifry/metaswarm"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "ajv": "8.17.1",
    "ajv-formats": "3.0.1",
    "yaml": "^2.4"
  },
  "devDependencies": {
    "@types/node": "20.14.10",
    "@vitest/coverage-v8": "1.6.1",
    "typescript": "5.4.5",
    "vitest": "1.6.1"
  }
}
